{
    "scheme": {
        "description": "Backend scheme (http/https)",
        "type": "string",
        "default": "http"
    },
    "host": {
        "description": "Backend host (use host.docker.internal if astrbot runs in docker)",
        "type": "string",
        "default": "127.0.0.1"
    },
    "port": {
        "description": "Backend port",
        "type": "int",
        "default": 8080
    },
    "path": {
        "description": "Dispatch path",
        "type": "string",
        "default": "/v1/dispatch"
    },
    "timeout_seconds": {
        "description": "Timeout in seconds",
        "type": "float",
        "default": 10.0
    }
}